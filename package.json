{
  "name": "postcss-reference",
  "version": "1.0.4",
  "description": "PostCSS plugin for referencing selectors' rules from CSS files and defined rulesets.",
  "scripts": {
    "prepublish": "babel test/test.js --presets env --out-dir dist --ignore /test/",
    "test-unformatted": "babel-tape-runner \"dist/test/*.js\"",
    "test": "npm run test-unformatted | tap-spec"
  },
  "main": "index.js",
  "keywords": [
    "postcss",
    "css",
    "postcss-plugin",
    "reference",
    "import",
    "extend"
  ],
  "author": {
    "name": "Samuel Allen",
    "email": "dehuszar@gmail.com"
  },
  "license": "MIT",
  "repository": "dehuszar/postcss-reference",
  "bugs": {
    "url": "https://github.com/dehuszar/postcss-reference/issues"
  },
  "homepage": "https://github.com/dehuszar/postcss-reference",
  "dependencies": {
    "postcss": "^6.0.14"
  },
  "devDependencies": {
    "babel": "^6.23.0",
    "babel-cli": "^6.26.0",
    "babel-preset-env": "^1.6.1",
    "babel-tape-runner": "^1.2.0",
    "postcss-import": "^11.0.0",
    "postcss-nested": "^2.1.2",
    "tap-spec": "^4.1.0",
    "tape": "^4.2.1"
  }
}
